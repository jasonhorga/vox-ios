# frozen_string_literal: true

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # ── 1. Load App Store Connect API Key ──
    # Sanitise the private key coming from GitHub Secrets / env vars.
    # GitHub Actions may inject literal "\n" sequences, trailing
    # whitespace, or null bytes (\x00) into the value – any of these
    # will cause OpenSSL to reject the key with a "null byte" error.
    raw_key = ENV["ASC_PRIVATE_KEY"] || ""
    clean_key = raw_key
                  .gsub("\\n", "\n")   # convert literal \n to real newlines
                  .gsub("\r", "")       # strip carriage returns
                  .delete("\u0000")     # remove null bytes
                  .strip                # trim leading/trailing whitespace

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: clean_key,
      is_key_content_base64: false,
      in_house: false
    )

    # ── 2. Ensure App & Bundle IDs exist ──
    # produce does not support API Key auth for the Developer Portal
    # (it uses the legacy Spaceship portal login that requires Apple ID).
    # Instead we call Spaceship::ConnectAPI directly, which honours the
    # API key loaded in step 1.

    app_identifiers = [
      "com.jasonhorga.vox",
      "com.jasonhorga.vox.keyboard"
    ]

    # 2a. Register Bundle IDs on the Developer Portal (if not yet present)
    app_identifiers.each do |bundle_id_str|
      begin
        existing = Spaceship::ConnectAPI::BundleId.find(bundle_id_str)
        if existing
          UI.success("Bundle ID '#{bundle_id_str}' already registered ✔")
        else
          UI.message("Registering Bundle ID '#{bundle_id_str}' on the Developer Portal…")
          Spaceship::ConnectAPI::BundleId.create(
            name: bundle_id_str.gsub(".", " ").split.map(&:capitalize).join(""),
            platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS,
            identifier: bundle_id_str
          )
          UI.success("Bundle ID '#{bundle_id_str}' registered ✔")
        end
      rescue => e
        UI.important("Bundle ID registration for '#{bundle_id_str}' skipped: #{e.message}")
      end
    end

    # 2b. Create app on App Store Connect (if not yet present)
    begin
      app = Spaceship::ConnectAPI::App.find("com.jasonhorga.vox")
      if app
        UI.success("App 'com.jasonhorga.vox' already exists on ASC (#{app.id}) ✔")
      else
        UI.message("Creating app 'Vox Input' on App Store Connect…")
        Spaceship::ConnectAPI::App.create(
          name: "Vox Input",
          version_string: "1.0.0",
          sku: "com.jasonhorga.vox",
          primary_locale: "zh-Hans",
          bundle_id: "com.jasonhorga.vox",
          platforms: [Spaceship::ConnectAPI::Platform::IOS]
        )
        UI.success("App 'Vox Input' created on ASC ✔")
      end
    rescue => e
      UI.important("App creation on ASC skipped: #{e.message}")
    end

    # ── 3. Code Signing (API Key auto-manages) ──
    get_certificates(
      api_key: api_key,
      platform: "ios"
    )

    # Main app provisioning profile
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.jasonhorga.vox",
      platform: "ios"
    )

    # Keyboard extension provisioning profile
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.jasonhorga.vox.keyboard",
      platform: "ios"
    )

    # ── 4. Increment build number from TestFlight ──
    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.jasonhorga.vox"
      ) + 1
    )

    # Also sync keyboard extension build number
    increment_build_number(
      build_number: lane_context[SharedValues::BUILD_NUMBER],
      xcodeproj: "VoxInput.xcodeproj"
    )

    # ── 5. Build ──
    # Let sigh (get_provisioning_profile) and Xcode automatically resolve
    # provisioning profiles.  We deliberately omit provisioningProfiles from
    # export_options so the build uses whatever profiles sigh downloaded.
    build_app(
      project: "VoxInput.xcodeproj",
      scheme: "VoxInput",
      configuration: "Release",
      output_directory: "build",
      output_name: "VoxInput.ipa",
      export_method: "app-store",
      clean: true
    )

    # ── 6. Upload to TestFlight ──
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: "Automated build from CI"
    )
  end
end
